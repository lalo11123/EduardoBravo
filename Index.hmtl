<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eduardo Bravo - Data Analyst & Power BI Designer</title>

    <!-- React y ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Animaciones, Google Fonts e Iconos -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        cvteal: '#F2C811', /* Amarillo corporativo Power BI para acentos, brillos y botones */
                        darkbg: '#050505', /* Negro absoluto (carbón oscuro) para el fondo */
                        darkcard: '#121212', /* Negro ligeramente más claro para el relieve de las tarjetas */
                        darkborder: '#262626', /* Gris oscuro sutil para separar bordes */
                        cvgreen: '#000000' /* Negro puro para sustituir el color del pie de página */
                    },
                    animation: {
                        'blob': 'blob 7s infinite',
                        'float': 'float 6s ease-in-out infinite',
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        blob: {
                            '0%': { transform: 'translate(0px, 0px) scale(1)' },
                            '33%': { transform: 'translate(30px, -50px) scale(1.1)' },
                            '66%': { transform: 'translate(-20px, 20px) scale(0.9)' },
                            '100%': { transform: 'translate(0px, 0px) scale(1)' }
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #111214;
            color: #f9fafb;
            scroll-behavior: smooth;
            overflow-x: hidden;
        }

        .nav-link {
            position: relative;
            transition: color 0.3s;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -4px;
            left: 0;
            background-color: #59B5B8;
            transition: width 0.3s;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .glass-header {
            background: rgba(17, 18, 20, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(89, 181, 184, 0.15);
        }

        .skill-tag {
            background: rgba(26, 28, 30, 0.8);
            border: 1px solid rgba(89, 181, 184, 0.15);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            backdrop-filter: blur(10px);
        }

        .skill-tag:hover {
            border-color: #59B5B8;
            color: #59B5B8;
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 10px 30px rgba(89, 181, 184, 0.2);
        }

        /* Hero Background Animado (Grid Datos) */
        .hero-bg {
            background-image:
                linear-gradient(to right, #1A1C1E 1px, transparent 1px),
                linear-gradient(to bottom, #1A1C1E 1px, transparent 1px);
            background-size: 50px 50px;
            mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 30%, rgba(0, 0, 0, 0) 100%);
            -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 30%, rgba(0, 0, 0, 0) 100%);
        }

        .project-card {
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .project-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px -5px rgba(0, 0, 0, 0.6), 0 0 20px rgba(89, 181, 184, 0.25);
            border-color: #59B5B8;
        }

        .image-wrapper img {
            transition: transform 0.6s ease;
        }

        .project-card:hover .image-wrapper img {
            transform: scale(1.08);
        }

        .glow-text {
            text-shadow: 0 0 20px rgba(89, 181, 184, 0.6);
        }

        .profile-img {
            border: 3px solid #59B5B8;
            box-shadow: 0 0 30px rgba(89, 181, 184, 0.4);
            transition: transform 0.5s ease;
        }

        .profile-img:hover {
            transform: scale(1.05) rotate(3deg);
        }
    </style>
</head>

<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        const Navbar = () => {
            const [scrolled, setScrolled] = useState(false);

            useEffect(() => {
                const handleScroll = () => { setScrolled(window.scrollY > 20); };
                window.addEventListener('scroll', handleScroll);
                return () => window.removeEventListener('scroll', handleScroll);
            }, []);

            return (
                <nav className={`fixed w-full z-50 transition-all duration-300 ${scrolled ? 'glass-header py-4 shadow-xl shadow-black/50' : 'py-6 bg-transparent'}`}>
                    <div className="container mx-auto px-6 flex justify-between items-center">
                        <div className="font-bold text-2xl tracking-wide flex items-center gap-2 animate__animated animate__fadeInLeft">
                            <i className='bx bx-pie-chart-alt text-cvteal text-3xl animate-pulse-slow'></i>
                            <span>Eduardo<span className="text-gray-400">Bravo</span></span>
                        </div>
                        <div className="hidden md:flex gap-8 text-sm font-medium animate__animated animate__fadeInDown">
                            <a href="#about" className="nav-link hover:text-cvteal uppercase tracking-widest">Perfil</a>
                            <a href="#skills" className="nav-link hover:text-cvteal uppercase tracking-widest">Skills</a>
                            <a href="#experiencia" className="nav-link hover:text-cvteal uppercase tracking-widest">Experiencia</a>
                            <a href="#portfolio" className="nav-link hover:text-cvteal uppercase tracking-widest">Dashboards</a>
                        </div>
                        <a href="#contact" className="hidden sm:block border border-cvteal text-cvteal hover:bg-cvteal hover:text-darkbg px-5 py-2 rounded font-semibold transition-all shadow-[0_0_15px_rgba(89,181,184,0.3)] hover:shadow-[0_0_25px_rgba(89,181,184,0.6)] animate__animated animate__fadeInRight">
                            Contactar
                        </a>
                    </div>
                </nav>
            );
        };

        const Hero = () => {
            return (
                <section id="about" className="relative pt-32 pb-20 lg:pt-48 lg:pb-32 min-h-screen flex items-center overflow-hidden">
                    {/* Grid animado de fondo y Esferas Brillantes (Glassmorphism dinámico) */}
                    <div className="absolute inset-0 hero-bg opacity-40 z-0"></div>
                    <div className="absolute top-1/4 right-1/4 w-96 h-96 bg-cvteal rounded-full mix-blend-screen filter blur-[150px] opacity-20 animate-blob z-0"></div>
                    <div className="absolute top-1/3 left-1/4 w-72 h-72 bg-blue-600 rounded-full mix-blend-screen filter blur-[150px] opacity-20 animate-blob animation-delay-2000 z-0"></div>

                    <div className="container mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center relative z-10">
                        <div className="animate__animated animate__fadeInUp">
                            <div className="flex items-center gap-6 mb-8">
                                <img src="perfil.png" alt="Eduardo Bravo"
                                    className="w-24 h-24 rounded-full object-cover profile-img bg-darkcard flex items-center justify-center text-xs text-center leading-tight"
                                    onError={(e) => {
                                        e.target.onerror = null;
                                        e.target.src = 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" fill="none"><circle cx="50" cy="50" r="50" fill="%232D3748"/><text x="50" y="55" font-family="sans-serif" font-size="24" fill="%2359B5B8" text-anchor="middle">EB</text></svg>';
                                    }} />
                                <div>
                                    <div className="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cvteal/30 bg-cvteal/10 text-cvteal font-medium text-xs shadow-[0_0_10px_rgba(89,181,184,0.2)]">
                                        <span className="relative flex h-2 w-2">
                                            <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-cvteal opacity-75"></span>
                                            <span className="relative inline-flex rounded-full h-2 w-2 bg-cvteal"></span>
                                        </span>
                                        Disponible para Consultoría
                                    </div>
                                </div>
                            </div>

                            <h1 className="text-5xl lg:text-7xl font-bold leading-tight mb-4">
                                Hola, soy <br />
                                <span className="text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-200 to-cvteal glow-text">Eduardo Bravo</span>
                            </h1>
                            <h2 className="text-2xl lg:text-3xl text-cvteal font-semibold mb-6 flex items-center gap-3">
                                <i className='bx bx-data animate-bounce text-3xl'></i> Data Analyst & Power BI Developer
                            </h2>
                            <div className="bg-darkcard/50 border border-darkborder p-5 rounded-xl mb-8 backdrop-blur-md relative overflow-hidden group">
                                <div className="absolute top-0 left-0 w-1 h-full bg-cvteal"></div>
                                <div className="flex gap-4 items-start">
                                    <span className="text-cvteal font-bold text-5xl">8<span className="text-3xl">+</span></span>
                                    <p className="text-gray-300 text-sm leading-relaxed text-justify relative z-10">
                                        Años de experiencia analizando datos a nivel regional. Transformo información cruda en inteligencia de negocios accionable, impulsando eficiencias operativas y rentabilidad corporativa. Mantenemos el balance ideal entre técnica superior y visión comercial estratégica.
                                    </p>
                                </div>
                            </div>
                            <div className="flex flex-wrap gap-4">
                                <a href="#portfolio" className="bg-cvteal text-darkbg px-8 py-3.5 rounded font-bold transition-all shadow-[0_0_20px_rgba(89,181,184,0.3)] hover:shadow-[0_0_40px_rgba(89,181,184,0.6)] hover:-translate-y-1 flex items-center gap-2">
                                    Visualizar Proyectos <i className='bx bx-right-arrow-alt text-xl'></i>
                                </a>
                                <div className="flex items-center gap-3 px-4 py-3 bg-darkcard/40 border border-darkborder rounded">
                                    <i className='bx bxs-graduation text-cvteal text-2xl'></i>
                                    <span className="text-xs text-gray-400">Ing. Ciencia de Datos<br />(En curso - ULA)</span>
                                </div>
                            </div>
                        </div>

                        {/* Gráficos / Componentes Flotantes Dinámicos */}
                        <div className="hidden lg:flex justify-end relative animate-float">
                            <div className="relative w-full max-w-lg">
                                {/* Visual KPI Card */}
                                <div className="bg-darkcard border border-darkborder p-6 rounded-xl shadow-2xl relative z-20 hover:-translate-y-3 transition-transform duration-700 backdrop-blur-xl">
                                    <div className="flex justify-between items-center mb-6 border-b border-darkborder pb-4">
                                        <h3 className="font-semibold text-gray-300 flex items-center gap-2">
                                            <i className='bx bx-line-chart text-cvteal'></i> Desempeño ROI
                                        </h3>
                                        <span className="text-xs bg-green-900/50 text-green-400 border border-green-800 px-2 py-1 rounded font-bold animate-pulse">+90% Precisión</span>
                                    </div>
                                    <div className="flex gap-4 items-end h-36 mt-4 px-2">
                                        {[30, 50, 45, 70, 60, 85, 100].map((height, i) => (
                                            <div key={i} className="w-full bg-darkborder rounded-t-sm relative group cursor-pointer overflow-hidden">
                                                <div
                                                    className={`absolute bottom-0 w-full rounded-t-sm transition-all duration-[1500ms] ${i === 6 ? 'bg-cvteal shadow-[0_0_15px_#59B5B8]' : 'bg-gray-600 hover:bg-gray-400'}`}
                                                    style={{ height: `${height}%` }}
                                                ></div>
                                            </div>
                                        ))}
                                    </div>
                                </div>

                                {/* Info Cards flotantes adicionales */}
                                <div className="absolute -bottom-10 -left-10 bg-darkcard/90 border border-cvteal/40 p-5 rounded-xl shadow-[0_0_30px_rgba(0,0,0,0.8)] z-30 animate-[bounce_6s_infinite] backdrop-blur-lg">
                                    <div className="flex items-center gap-3 mb-2">
                                        <i className='bx bx-time text-cvteal text-xl'></i>
                                        <p className="text-gray-400 text-sm">Ahorro de Tiempo</p>
                                    </div>
                                    <p className="text-4xl font-bold text-white flex items-end gap-1">70<span className="text-cvteal text-2xl mb-1 font-bold">%</span></p>
                                </div>

                                <div className="absolute top-10 -right-8 bg-darkcard/90 border border-cvteal/50 p-4 rounded-xl shadow-2xl z-30 animate-pulse-slow backdrop-blur-lg">
                                    <div className="w-12 h-12 rounded-full border-4 border-t-cvteal border-r-cvteal border-b-darkborder border-l-darkborder animate-spin flex items-center justify-center">
                                        <div className="w-2 h-2 rounded-full bg-cvteal"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            );
        };

        const Skills = () => {
            const skillBars = [
                { name: "Power BI (Visualización Premium)", level: 98 },
                { name: "Python (Pandas, PyAutoGUI, Numpy, Selenium)", level: 90 },
                { name: "DAX & Modelado de Datos", level: 95 },
                { name: "Figma (Diseño de Dashboards)", level: 85 }
            ];

            const infoCards = [
                { title: "Visualización & Análisis", icon: "bx-pie-chart-alt-2", desc: "Desarrollo de tableros profesionales utlizando Power BI, Python y Excel." },
                { title: "Diseño de Dashboards", icon: "bx-palette", desc: "Interfaces premium utilizando Figma para proyectos BI ejecutivos." },
                { title: "Automatización Python", icon: "bx-rocket", desc: "Scripts Python para extracción y procesamiento automático de datos, DAX complejo." },
                { title: "Visión Comercial", icon: "bx-line-chart-down", desc: "Experiencia operativa en ventas y finanzas para maximizar resultados de negocio." }
            ];

            return (
                <section id="skills" className="py-24 bg-darkbg border-y border-darkborder relative z-10 overflow-hidden">
                    <div className="absolute top-0 right-0 w-[500px] h-[500px] bg-cvteal/5 rounded-full blur-3xl z-0"></div>
                    <div className="container mx-auto px-6 relative z-10">
                        <div className="text-center mb-16 animate__animated animate__fadeIn">
                            <h2 className="text-4xl font-bold mb-3"><span className="text-cvteal">Habilidades</span> de Inteligencia</h2>
                            <p className="text-gray-400 text-lg">El stack técnico detrás de la magia de datos.</p>
                        </div>

                        <div className="grid lg:grid-cols-2 gap-16 max-w-6xl mx-auto">
                            {/* Barras dinámicas estilo progreso */}
                            <div className="space-y-8">
                                {skillBars.map((skill, idx) => (
                                    <div key={idx} className="skill-tag p-5 rounded-xl flex flex-col gap-3 group">
                                        <div className="flex justify-between font-semibold items-center">
                                            <span className="text-gray-200 group-hover:text-white transition-colors">{skill.name}</span>
                                            <span className="text-cvteal text-sm bg-cvteal/10 px-2 py-1 rounded">{skill.level}%</span>
                                        </div>
                                        <div className="w-full bg-darkbg rounded-full h-2 overflow-hidden shadow-inner">
                                            <div className="bg-gradient-to-r from-cvteal/50 to-cvteal h-2 rounded-full shadow-[0_0_10px_#59B5B8] group-hover:scale-y-110 transition-transform origin-left" style={{ width: `${skill.level}%` }}></div>
                                        </div>
                                    </div>
                                ))}
                            </div>

                            {/* Tarjetas informativas extraídas del CV */}
                            <div className="grid md:grid-cols-2 gap-6">
                                {infoCards.map((card, idx) => (
                                    <div key={idx} className="bg-darkcard/50 border border-darkborder p-6 rounded-xl hover:border-cvteal transition-all group backdrop-blur-md">
                                        <div className="w-12 h-12 rounded-lg bg-darkbg flex items-center justify-center mb-4 group-hover:bg-cvteal transition-colors shadow-lg">
                                            <i className={`bx ${card.icon} text-2xl text-cvteal group-hover:text-darkbg transition-colors`}></i>
                                        </div>
                                        <h3 className="text-sm font-bold text-white mb-2">{card.title}</h3>
                                        <p className="text-xs text-gray-400 group-hover:text-gray-300 transition-colors leading-relaxed">
                                            {card.desc}
                                        </p>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                </section>
            );
        };

        const ExperienceTimeline = () => {
            const jobs = [
                {
                    title: "LIDER DE PLANEACION FINANCIERA",
                    date: "MAY 2025 - ACTUAL",
                    icon: "bx-line-chart flex items-center justify-center text-cvteal text-xl font-bold bg-darkcard w-full h-full rounded-full border-2 border-cvteal shadow-[0_0_15px_rgba(242,200,17,0.4)]",
                    desc: "Desarrollé modelos analíticos en Power BI para el seguimiento de CAPEX y OPEX, incorporando proyecciones de forecast e integrando múltiples fuentes de datos.",
                    logros: "Permitió automatizar la actualización de información, mejorar la visibilidad del gasto, reducir los tiempos de análisis en más del 50% y fortalecer la toma de decisiones estratégicas."
                },
                {
                    title: "GRTE. REGIONAL SOPORTE A OPERACIÓN",
                    date: "DIC 2023 - MAY 2025",
                    icon: "bx-bar-chart-alt-2 flex items-center justify-center text-gray-400 text-xl font-bold bg-darkcard w-full h-full rounded-full border-2 border-gray-600",
                    desc: "Automatización de procesos con Python. Desarrollo de tableros interactivos Power BI en tiempo real para cobranzas y comercial. Supervisión de equipo técnico. DAX avanzado.",
                    logros: "Reducción del 70% en tiempo de reportes corporativos y mejora de precisión del 90% en la recolección de datos operativos mediante automatización."
                },
                {
                    title: "COORD. SOPORTE A LA OPERACIÓN",
                    date: "MAY 2021 - DIC 2023",
                    icon: "bx-server flex items-center justify-center text-gray-400 text-xl font-bold bg-darkcard w-full h-full rounded-full border-2 border-gray-600",
                    desc: "Análisis estadísticos de fuentes complejas (ETL). Colaboración con equipos multidisciplinarios para detectar problemas de negocio basados en hallazgos analíticos. ",
                    logros: "Reducción del costo operativo mensual en un 31% ($60,000 MXN) usando modelos de inteligencia artificial e interfaces automatizadas."
                }
            ];

            return (
                <section id="experiencia" className="py-24 bg-darkbg relative z-10">
                    <div className="container mx-auto px-6 max-w-full lg:px-16">
                        <div className="text-center mb-16">
                            <h2 className="text-4xl font-bold mb-3"><span className="text-cvteal">Trayectoria</span> Profesional</h2>
                            <p className="text-gray-400 text-lg">Impacto corporativo validado por métricas reales y automatización.</p>
                        </div>

                        <div className="relative w-full">
                            {/* Línea lateral izquierda */}
                            <div className="absolute left-6 md:left-10 top-0 bottom-0 w-[2px] bg-gradient-to-b from-cvteal via-darkborder to-transparent"></div>

                            <div className="space-y-8">
                                {jobs.map((job, idx) => (
                                    <div key={idx} className="relative flex items-start group">

                                        {/* Círculo Timeline en la línea */}
                                        <div className="absolute left-6 md:left-10 top-6 w-12 h-12 -translate-x-1/2 z-10 animate-pulse-slow">
                                            <i className={job.icon}></i>
                                        </div>

                                        {/* Tarjeta de contenido más compacta a la derecha */}
                                        <div className="w-full pl-16 md:pl-20">
                                            <div className="bg-darkcard/40 backdrop-blur border border-darkborder p-5 md:p-6 rounded-xl group-hover:border-cvteal transition-all group-hover:-translate-y-1 shadow-lg relative overflow-hidden">
                                                <div className="absolute -top-10 -right-10 w-24 h-24 bg-cvteal/10 rounded-full blur-xl group-hover:bg-cvteal/20 transition-all"></div>

                                                <div className="flex flex-col md:flex-row md:items-center justify-between gap-3 mb-3 relative z-20">
                                                    <h3 className="text-lg font-bold text-white flex-1">{job.title}</h3>
                                                    <span className="text-xs font-bold text-cvteal tracking-widest bg-cvteal/10 border border-cvteal/20 px-3 py-1 rounded-full whitespace-nowrap shadow-inner">{job.date}</span>
                                                </div>

                                                <p className="text-sm text-gray-400 mb-4 leading-relaxed relative z-20 text-justify">{job.desc}</p>

                                                <div className="bg-darkbg/80 border-l-2 border-cvteal p-3 md:p-4 rounded shadow-inner text-left relative z-20 hover:bg-darkbg transition-colors">
                                                    <span className="text-xs font-bold text-cvteal uppercase flex items-center gap-1.5 mb-1.5"><i className='bx bx-check-square text-lg'></i> Impacto Destacado</span>
                                                    <p className="text-xs text-gray-300 leading-relaxed text-justify">{job.logros}</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                </section>
            );
        };

        const Portfolio = () => {
            const projects = [
                {
                    title: "DASHBOARD VENTAS",
                    desc: "Visualiza el rendimiento comercial mediante métricas clave, análisis de tendencias y comparativas.",
                    tags: ["Power BI", "SQL Server", "DAX"],
                    img: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                },
                {
                    title: "PUNTOS DE VENTA (PDV)",
                    desc: "Centraliza y analiza información clave de las operaciones logísticas y comerciales en diferentes tiendas y sucursales físicas.",
                    tags: ["Python", "ETL", "Dataviz"],
                    img: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                },
                {
                    title: "DASHBOARD VEHÍCULOS",
                    desc: "Métricas clave del negocio: cantidad de vehículos vendidos, popularidad mediante Pareto, tendencias longitudinales de ventas.",
                    tags: ["Excel Analytics", "Figma BI", "PyAutoGUI"],
                    img: "https://images.unsplash.com/photo-1543286386-713bdd548da4?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                }
            ];

            return (
                <section id="portfolio" className="py-24 relative z-10 bg-darkbg border-t border-darkborder">
                    <div className="container mx-auto px-6 max-w-6xl">
                        <div className="mb-16 flex flex-col md:flex-row justify-between items-end gap-6">
                            <div>
                                <h2 className="text-4xl font-bold mb-3">Galería de <span className="text-cvteal">Dashboards</span></h2>
                                <p className="text-gray-400 text-lg">Reportes visuales de alto impacto diseñados a medida.</p>
                            </div>
                            <span className="text-cvteal text-sm hidden md:flex items-center gap-2 bg-cvteal/10 px-4 py-2 rounded-full border border-cvteal/30">
                                <i className='bx bxs-pointer animate-pulse'></i> Interfaz Interactiva
                            </span>
                        </div>

                        <div className="grid lg:grid-cols-3 gap-8">
                            {projects.map((proj, idx) => (
                                <div key={idx} className="bg-darkcard rounded-xl overflow-hidden border border-darkborder project-card flex flex-col h-full group">
                                    <div className="h-56 overflow-hidden relative image-wrapper bg-darkbg">
                                        <div className="absolute inset-0 bg-cvteal/20 mix-blend-overlay z-10 group-hover:opacity-0 transition-opacity"></div>
                                        <img src={proj.img} alt={proj.title} className="w-full h-full object-cover grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100" />
                                        <div className="absolute inset-0 bg-gradient-to-t from-darkcard to-transparent z-20 opacity-80"></div>

                                        {/* Botón Flotante */}
                                        <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-30 bg-cvteal/90 backdrop-blur text-white px-5 py-2 rounded-full font-bold shadow-xl opacity-0 group-hover:opacity-100 transition-all scale-75 group-hover:scale-100 flex items-center gap-2 cursor-pointer">
                                            Ver Detalles <i className='bx bx-search'></i>
                                        </div>
                                    </div>
                                    <div className="p-6 relative z-30 -mt-10">
                                        <div className="bg-darkcard p-4 rounded-xl border border-darkborder shadow-[0_-10px_15px_rgba(0,0,0,0.5)] flex-1 h-full flex flex-col justify-between">
                                            <div>
                                                <h3 className="text-xl font-bold mb-3 text-white group-hover:text-cvteal transition-colors flex items-center gap-2">
                                                    <i className='bx bx-check-shield text-cvteal text-sm'></i> {proj.title}
                                                </h3>
                                                <p className="text-gray-400 text-sm leading-relaxed mb-6">
                                                    {proj.desc}
                                                </p>
                                            </div>
                                            <div className="flex flex-wrap gap-2 mt-auto pt-4 border-t border-darkborder">
                                                {proj.tags.map((tag, i) => (
                                                    <span key={i} className="text-[10px] font-bold uppercase tracking-wider bg-darkbg text-gray-300 border border-gray-700 px-2 py-1 rounded hover:border-cvteal transition-colors">
                                                        {tag}
                                                    </span>
                                                ))}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </section>
            );
        };

        const FooterContact = () => {
            return (
                <footer id="contact" className="relative z-10 border-t border-cvteal/30">
                    <div className="bg-cvgreen py-12 lg:py-16 mt-0 shadow-[0_-20px_50px_rgba(84,122,90,0.15)] overflow-hidden relative">
                        {/* Decoración gráfica del pie de página */}
                        <div className="absolute top-0 right-0 w-full h-full opacity-10" style={{ backgroundImage: 'radial-gradient(circle at 80% 50%, #fff 1px, transparent 1px)', backgroundSize: '20px 20px' }}></div>

                        <div className="container mx-auto px-6 max-w-6xl flex flex-col md:flex-row justify-between items-center gap-8 text-sm font-medium relative z-10">

                            <div className="flex flex-col gap-5 w-full md:w-auto">
                                <a href="https://lalo11123.github.io/databixpy/#" target="_blank" className="flex items-center gap-4 text-white hover:text-cvteal transition-colors group bg-black/10 px-6 py-3 rounded-xl border border-white/10 hover:border-cvteal/50 hover:shadow-[0_0_20px_rgba(89,181,184,0.3)]">
                                    <div className="bg-white/20 p-2 rounded-lg group-hover:bg-cvteal/20 transition-colors"><i className='bx bx-globe text-2xl'></i></div>
                                    <span className="text-base tracking-wide">Sitio Web / GitHub Pages</span>
                                </a>
                                <a href="https://wa.me/525568189842" target="_blank" className="flex items-center gap-4 text-white hover:text-green-300 transition-colors group bg-black/10 px-6 py-3 rounded-xl border border-white/10 hover:border-green-400/50 hover:shadow-[0_0_20px_rgba(74,222,128,0.3)]">
                                    <div className="bg-white/20 p-2 rounded-lg group-hover:bg-green-400/20 transition-colors"><i className='bx bxl-whatsapp text-2xl'></i></div>
                                    <span className="text-base tracking-wide font-bold">+52 55 68189842</span>
                                </a>
                            </div>

                            <div className="flex justify-start md:justify-end w-full md:w-auto">
                                <a href="https://www.linkedin.com/in/eduardo-bravo-1a0a6a281/" target="_blank" className="flex items-center gap-4 text-white hover:text-[#0077b5] transition-colors group bg-black/10 px-6 py-3 rounded-xl border border-white/10 hover:border-[#0077b5]/50 hover:shadow-[0_0_20px_rgba(0,119,181,0.5)]">
                                    <div className="bg-white/20 p-2 rounded-lg group-hover:bg-[#0077b5]/20 group-hover:text-white transition-colors"><i className='bx bxl-linkedin-square text-4xl'></i></div>
                                    <div className="flex flex-col">
                                        <span className="font-bold text-lg mb-1">LinkedIn</span>
                                        <span className="text-xstext-white/70 overflow-hidden text-ellipsis whitespace-nowrap hidden sm:block">eduardo-bravo-1a0a6a281</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </footer>
            );
        };

        const App = () => {
            return (
                <div className="min-h-screen relative font-sans">
                    <Navbar />
                    <Hero />
                    <Skills />
                    <ExperienceTimeline />
                    <Portfolio />
                    <FooterContact />
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>

</html>
